# LLM provider keys
DEEPSEEK_API_KEY=your_deepseek_api_key
QWEN_API_KEY=your_qwen_api_key

# PostgreSQL container
POSTGRES_USER=postgres
POSTGRES_PASSWORD=chatbi_dev_password
POSTGRES_DB=sales_chat

# ChatBI database connection
db_host=postgres
db_port=5432
user=postgres
password=chatbi_dev_password
dbname=sales_chat

# MCP services run inside the backend container
server_url=127.0.0.1
server_api_url=http://127.0.0.1:9008/chatbi_service

# Security controls
CHATBI_CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
CHATBI_SQL_MAX_ROWS=200
CHATBI_SQL_TIMEOUT_MS=5000
CHATBI_ENABLE_PYTHON_EXEC=false
CHATBI_AUDIT_ENABLED=true
CHATBI_AUDIT_LOG_PATH=
CHATBI_AUDIT_ADMIN_TOKEN=
CHATBI_USE_POSTGRES_AUDIT=true

# Metadata persistence
CHATBI_USE_POSTGRES_METADATA=true
